          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('P2 play returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('word is TE and turn back to P1', function () {",
              "  pm.expect(body.currentWord).to.eql('TE');",
              "  pm.expect(body.activePlayer).to.eql(pm.collectionVariables.get('p1Token'));",
              "});"
            ]
          }
        }
      ]
    },
