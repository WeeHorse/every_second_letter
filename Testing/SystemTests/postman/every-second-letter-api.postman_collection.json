  "item": [
    {
      "name": "Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('health payload has status ok', function () {",
              "  pm.expect(body.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create game",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/games",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "games"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('create game returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('gameId', body.gameId);",
              "pm.collectionVariables.set('p1Token', body.playerToken);",
              "pm.test('create payload includes ids', function () {",
              "  pm.expect(body.gameId).to.be.a('string');",
              "  pm.expect(body.playerToken).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Join game as player 2",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/games/{{gameId}}/join",
          "host": [
            "{{baseUrl}}"
          ],
