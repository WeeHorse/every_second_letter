{
  "info": {
    "_postman_id": "7c45b18b-cf90-4a8c-925b-c0fd62269f26",
    "name": "EverySecondLetter API - Minimal Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create game as Player 1",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/games?playerName=Alice",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "games"
          ],
          "query": [
            {
              "key": "playerName",
              "value": "Alice"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('create game returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('gameId', body.gameId);",
              "pm.collectionVariables.set('p1Token', body.playerId);",
              "pm.test('response includes gameId and playerId', function () {",
              "  pm.expect(body.gameId).to.be.a('string');",
              "  pm.expect(body.playerId).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Join game as Player 2",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/games/{{gameId}}/join?playerName=Bob",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "games",
            "{{gameId}}",
            "join"
          ],
          "query": [
            {
              "key": "playerName",
              "value": "Bob"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('join returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('p2Token', body.playerId);",
              "pm.test('join returns playerId', function () {",
              "  pm.expect(body.playerId).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get game state after join",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/games/{{gameId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "games",
            "{{gameId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('get state returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('state shows InProgress with 2 players', function () {",
              "  pm.expect(body.status).to.eql('InProgress');",
              "  pm.expect(body.players.length).to.eql(2);",
              "  pm.expect(body.activePlayerId).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Reject out-of-turn play",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Player-Token",
            "value": "{{p2Token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"letter\":\"X\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/games/{{gameId}}/letter",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "games",
            "{{gameId}}",
            "letter"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('out-of-turn play is rejected', function () {",
              "  pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "P1 plays letter T",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Player-Token",
            "value": "{{p1Token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"letter\":\"T\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/games/{{gameId}}/letter",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "games",
            "{{gameId}}",
            "letter"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('play letter returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('word updated and turn rotated to P2', function () {",
              "  pm.expect(body.currentWord).to.eql('T');",
              "  pm.expect(body.activePlayer).to.eql(pm.collectionVariables.get('p2Token'));",
              "});",
              "pm.collectionVariables.set('nextPlayer', body.activePlayer);"
            ]
          }
        }
      ]
    },
    {
